#!/bin/bash

# exit on error
set -e

CONFIG_PATH="$HOME/.config/pixel/config.json"
BREW_PREFIX=$(brew --prefix pixel)
EXAMPLE_PATH="${BREW_PREFIX}/config/config.example.json"

if [[ ! -f "$CONFIG_PATH" ]]; then
	echo "❌ Config not found at $CONFIG_PATH"
	read -rp "❔ Create config from example? [y/N]: " create_config
	if [[ "$create_config" =~ ^[Yy]$ ]]; then
    	mkdir -p "$(dirname "$CONFIG_PATH")"
    	cp "$EXAMPLE_PATH" "$CONFIG_PATH"
    	echo "✅ Config created at $CONFIG_PATH. Please review and fill it in."
		exit 1
	else
		echo "Aborted. Please copy config/config.example.json to ~/.config/pixel/config.json and fill it in."
		exit 1
	fi
fi

# Stores the first command-line argument (e.g., init or deploy) into the COMMAND variable.
COMMAND=$1

# Removes the first argument (already stored in COMMAND) from the list of $@ arguments.
shift || true

case "$COMMAND" in
  -v|--version)
	brew info pixel --json | jq -r '.[0].installed[0].version' | xargs echo "Pixel CLI version"
	;;
  --help|-h|wiki)
	open https://github.com/Pageking/pixel/wiki
	;;
  update|upgrade)
	source "${BREW_PREFIX}/libexec/lib/helpers/update-pixel.sh"
	update_pixel
	;;
  clone-project)
    source "${BREW_PREFIX}/libexec/lib/helpers/clone-project.sh"
    clone_project "$@"
    ;;
  init)
    source "${BREW_PREFIX}/libexec/lib/init.sh"
    ;;
  init-test)
    source "${BREW_PREFIX}/libexec/lib/init-test.sh"
    ;;
  init-prod)
	source "${BREW_PREFIX}/libexec/lib/init-prod.sh"
	;;
  prod-set-core-version)
	source "${BREW_PREFIX}/libexec/lib/helpers/prod/prod-set-core-version.sh"
	prod_set_core_version
	;;
  sync-dev-to-test|sync-dev-test)
	source "${BREW_PREFIX}/libexec/lib/helpers/test/sync-dev-to-test.sh"
	sync_dev_to_test "$@"
	;;
  sync-test-to-dev|sync-test-dev)
	source "${BREW_PREFIX}/libexec/lib/helpers/test/sync-test-to-dev.sh"
	sync_test_to_dev "$@"
	;;
  sync-dev-to-prod|sync-dev-prod)
	source "${BREW_PREFIX}/libexec/lib/helpers/prod/sync-dev-to-prod.sh"
	sync_dev_to_prod "$@"
	;;
  sync-prod-to-dev|sync-prod-dev)
	source "${BREW_PREFIX}/libexec/lib/helpers/prod/sync-prod-to-dev.sh"
	sync_prod_to_dev "$@"
	;;
  test-pull-main)
	source "${BREW_PREFIX}/libexec/lib/helpers/test/test-pull-main.sh"
	test_pull_main
	;;
  test-set-core-version)
	source "${BREW_PREFIX}/libexec/lib/helpers/test/test-set-core-version.sh"
	test_set_core_version
	;;
  remove-test)
	source "${BREW_PREFIX}/libexec/lib/helpers/test/remove-test.sh"
	removeTest
	;;
  get-github-var)
	if [[ $# -ne 1 ]]; then
		echo "❌ Usage: pixel get-github-var <variable_name>"
		exit 1
	fi
	source "${BREW_PREFIX}/libexec/lib/helpers/env/get-github-var.sh"
	VAR_NAME="$1"
	RESULT=$(get_github_var "$VAR_NAME")
	echo "$RESULT"
	;;
  get-core-version)
	source "${BREW_PREFIX}/libexec/lib/helpers/env/get-core-version.sh"
	get_core_version
	;;
  set-core-version)
	source "${BREW_PREFIX}/libexec/lib/helpers/env/set-core-version.sh"
	set_core_version
	;;
  create-layout)
	source "${BREW_PREFIX}/libexec/lib/helpers/create-layout.sh"
	create_layout "$@"
	;;
  renew-connection-info)
	source "${BREW_PREFIX}/libexec/lib/helpers/env/renew-connection-info.sh"
	renew_connection_info "$1"
	;;
  mira)
	SUBCOMMAND="$1"
	shift || true
	export MIRA_LAYOUTS="$HOME/.config/pixel/mira/flex/content/layouts"
	export MIRA_COMPONENTS="$HOME/.config/pixel/mira/flex/components"
	case "$SUBCOMMAND" in 
		setup)
			source "${BREW_PREFIX}/libexec/lib/helpers/mira/setup.sh"
			setup_mira
			;;
		list)
			source "${BREW_PREFIX}/libexec/lib/helpers/mira/list.sh"
			list_mira
			;;
		clone)
			source "${BREW_PREFIX}/libexec/lib/helpers/mira/clone-layout.sh"
			clone_layout "$@"
			;;
		update)
			source "${BREW_PREFIX}/libexec/lib/helpers/mira/update.sh"
			update_mira
			;;
	esac
	;;
  *)
    echo "Usage: pixel <command>"
	echo ""
    echo "Initialize Commands:"
    echo "    init					Initialize GitHub repo + dev environment"
    echo "    init-test					Initialize test environment on Plesk server"
    echo "    init-prod					Initialize production environment on Cloudways server"
    echo "    clone-project [project-name]		Clone an existing project and set up local dev environment"
	echo ""
	echo "Sync Commands:"
	echo "    sync-dev-to-test				Sync plugins and database from dev to test environment"
	echo "    sync-test-to-dev				Sync plugins and database from test to dev environment"
	echo "    sync-dev-to-prod				Sync plugins and database from dev to production environment"
	echo "    sync-prod-to-dev				Sync plugins and database from production to development environment"
	echo ""
	echo "All sync commands can be used with the following flags:"
	echo "    --no-database          			Skip database synchronization"
	echo "    --no-plugins           			Skip plugin synchronization"
	echo "    --no-media             			Skip uploads/media synchronization"
	echo ""
	echo "Mira Commands:"
	echo "    setup					Setup the Mira repo in your /.config/ folder."
	echo "    list					List all available Mira layouts."
	echo "    update					Update the Mira repo in your /.config/ folder by doing: git pull origin."
	echo "    clone <block-name>				Clone a specific layout from the Mira repo."
	echo ""
	echo "Create Commands:"
	echo "    create-layout <layout-slug> <layout-label> <layout-category>	Creates a new layout in the layouts folder based on templates in the pixel repo."
	echo ""
	echo "Management Commands:"
	echo "    set-core-version				Sync GitHub CORE_VERSION variable with local pk-theme version"
	echo "    get-core-version				Display the current local pk-theme version tag"
	echo "    test-set-core-version			Deploy CORE_VERSION to the test environment"
	echo "    prod-set-core-version			Deploy CORE_VERSION to the production environment"
	echo "    renew-connection-info			Re-enter the connection info for test or production"
	echo "    test-pull-main				Pull latest main branch on test environment"
	echo "    remove-test					Remove test environment from Plesk server"
	echo "    get-github-var <variable_name>		Get a GitHub Actions variable from the project repo"
	echo "    upgrade | update				Check for updates and install them directly"
	echo "    -v (--version)				Display version information"
	echo "    -h (--help) | wiki			Open the Pixel wiki page in your browser"
    ;;
esac
